# Production environment template for Railway.
# Copy each VAR=value line into Railway → Service → Variables.
# DATABASE_URL and REDIS_URL are auto-injected by Railway plugins; do NOT set them manually.

# ─── App ───────────────────────────────────────────────
PORT=3000
NODE_ENV=production
COMPANY_NAME=Ecolare Solar
COMPANY_CITY=Fortaleza
SDR_NAME=Ana
LOG_LEVEL=info

# Set to true ONLY for staging; in production leave unset (test panel stays disabled)
# ENABLE_TEST_PANEL=true

# ─── Database (Railway Postgres plugin auto-injects) ───
# DATABASE_URL=postgresql://...

# ─── Redis (Railway Redis plugin auto-injects) ─────────
# REDIS_URL=redis://...

# ─── Anthropic Claude ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-PLACEHOLDER
ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── OpenAI (Whisper + future TTS) ─────────────────────
OPENAI_API_KEY=sk-proj-PLACEHOLDER
OPENAI_WHISPER_MODEL=whisper-1

# ─── WhatsApp ─ Cloud API (META oficial) ───────────────
WHATSAPP_PROVIDER=meta
META_CLOUD_PHONE_NUMBER_ID=PLACEHOLDER
META_CLOUD_ACCESS_TOKEN=PLACEHOLDER
META_CLOUD_WABA_ID=PLACEHOLDER
META_VERIFY_TOKEN=PLACEHOLDER_random_string_you_pick
META_APP_SECRET=PLACEHOLDER

# ─── Google Calendar + Maps ────────────────────────────
GOOGLE_CLIENT_ID=937926087803-33f14sur8c5to4hu3p51sl4qfp153v1v.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-PLACEHOLDER
GOOGLE_REDIRECT_URI=https://YOUR-DOMAIN.com.br/auth/google/callback
GOOGLE_REFRESH_TOKEN=PLACEHOLDER_run_/auth/google_once_in_prod
GOOGLE_MAPS_API_KEY=AIzaSyPLACEHOLDER

# ─── CRM (optional, for later) ─────────────────────────
HUBSPOT_API_KEY=

# ─── Notifications (optional but recommended) ──────────
SLACK_WEBHOOK_URL=
TEAM_WHATSAPP_GROUP_ID=

# ─── Error tracking (Sentry — free tier) ───────────────
SENTRY_DSN=

# ─── Business rules ────────────────────────────────────
FIRST_CONTACT_DELAY_MINUTES=2
BUSINESS_HOURS_START=8
BUSINESS_HOURS_END=18
MIN_QUALIFICATION_SCORE=50
