# ─────────────────────────────────────────────────────
# SDR IA — Ecolare Solar  |  .env.example
# Copie para .env e preencha os valores antes de rodar
# ─────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────
PORT=3000
NODE_ENV=development         # development | production
LOG_LEVEL=info               # trace | debug | info | warn | error

# ── Banco de dados (obrigatório) ──────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/sdr_solar

# ── Redis / BullMQ (obrigatório) ──────────────────────
REDIS_URL=redis://localhost:6379

# ── Anthropic / Claude (obrigatório) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Identidade do agente ──────────────────────────────
SDR_NAME=Ana
COMPANY_NAME=Ecolare Solar
COMPANY_CITY=Fortaleza

# ── Evolution API / WhatsApp Baileys (obrigatório) ────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=sdr-solar

# ── Meta / WhatsApp Business Cloud API (opcional) ─────
META_VERIFY_TOKEN=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ID=

# ── Google Calendar (opcional) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_REFRESH_TOKEN=

# ── Notificações (opcional) ───────────────────────────
SLACK_WEBHOOK_URL=
TEAM_WHATSAPP_GROUP_ID=

# ── HubSpot CRM (opcional) ────────────────────────────
HUBSPOT_API_KEY=

# ── Sentry (opcional) ─────────────────────────────────
SENTRY_DSN=

# ── Regras de negócio ─────────────────────────────────
FIRST_CONTACT_DELAY_MINUTES=2    # delay entre chegada do lead e 1o contato
BUSINESS_HOURS_START=8           # hora de início do atendimento
BUSINESS_HOURS_END=18            # hora de fim do atendimento
MIN_QUALIFICATION_SCORE=50       # score mínimo para qualificar automaticamente
